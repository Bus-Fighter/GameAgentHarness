{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://game-agent-harness.local/schemas/profile.schema.json",
  "title": "Game Agent Harness Project Profile",
  "type": "object",
  "required": ["schemaVersion", "project", "engine"],
  "properties": {
    "schemaVersion": { "type": "integer", "const": 1 },
    "project": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "root": { "type": ["string", "null"] }
      },
      "additionalProperties": true
    },
    "engine": {
      "oneOf": [
        { "type": "string", "minLength": 1 },
        {
          "type": "object",
          "required": ["name"],
          "properties": {
            "name": { "type": "string", "minLength": 1 },
            "version": { "type": "string" }
          },
          "additionalProperties": true
        }
      ]
    },
    "traceDir": { "type": "string" },
    "importantEntities": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["role", "match"],
        "properties": {
          "role": { "type": "string", "minLength": 1 },
          "match": { "type": "object", "additionalProperties": true }
        },
        "additionalProperties": true
      }
    },
    "semanticEvents": {
      "type": "array",
      "items": {
        "oneOf": [
          { "type": "string", "minLength": 1 },
          {
            "type": "object",
            "required": ["type"],
            "properties": {
              "type": { "type": "string", "minLength": 1 },
              "description": { "type": "string" }
            },
            "additionalProperties": true
          }
        ]
      }
    },
    "validationScenarios": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "safety": { "type": "object", "additionalProperties": true }
  },
  "additionalProperties": true
}
