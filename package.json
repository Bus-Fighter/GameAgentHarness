{
  "name": "game-agent-harness",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Trace-first runtime evidence harness for game development agents.",
  "bin": {
    "harness": "./src/cli.js"
  },
  "scripts": {
    "start": "node ./src/cli.js host start",
    "predashboard": "npm run build:dashboard",
    "dashboard": "node ./src/cli.js dashboard start",
    "predashboard:lan": "npm run build:dashboard",
    "dashboard:lan": "node ./src/cli.js dashboard start --host 0.0.0.0 --dashboard-host 0.0.0.0",
    "build:dashboard": "vite build",
    "dev:dashboard": "vite",
    "test": "node --test",
    "mcp": "node ./src/cli.js mcp serve",
    "sample": "node ./src/cli.js dev emit-sample",
    "summary": "node ./src/cli.js trace summarize latest",
    "test-field": "node ./src/cli.js dev create-test-field --profile examples/test-field.profile.json",
    "context": "node ./src/cli.js context current latest --profile examples/test-field.profile.json",
    "validate:test-field": "node ./src/cli.js validate scenario --scenario examples/test-field.validation.json --profile examples/test-field.profile.json"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.4",
    "@codemirror/legacy-modes": "^6.5.3",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@gitgraph/react": "^1.6.0",
    "codemirror": "^6.0.2",
    "lucide-react": "^1.21.0",
    "react": "^19.3.0-canary-68631c04-20260626",
    "react-dom": "^19.3.0-canary-68631c04-20260626"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.5.2",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "vite": "^8.1.0"
  }
}
