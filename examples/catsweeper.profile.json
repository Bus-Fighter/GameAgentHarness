{
  "schemaVersion": 1,
  "project": {
    "name": "CatSweeper",
    "root": "../.."
  },
  "engine": {
    "name": "godot",
    "version": "4.x"
  },
  "traceDir": "../traces",
  "importantEntities": [
    {
      "role": "stage_controller",
      "match": { "nodeName": "StageController" }
    },
    {
      "role": "stage_map",
      "match": { "nodeName": "StageMap" }
    },
    {
      "role": "grid_session",
      "match": { "className": "GridSession" }
    },
    {
      "role": "player_health",
      "match": { "className": "PlayerHealthSystem" }
    },
    {
      "role": "player_progression",
      "match": { "className": "PlayerProgressionSystem" }
    }
  ],
  "interestingSignals": [
    "OnStageInitialized"
  ],
  "semanticEvents": [
    {
      "type": "input.pointer.pressed",
      "description": "Player clicked or touched the stage."
    },
    {
      "type": "game.reveal.result",
      "description": "Grid reveal or mine/cat catch result."
    },
    {
      "type": "player.hp_changed",
      "description": "Player HP changed after gameplay logic."
    },
    {
      "type": "player.exp_changed",
      "description": "Player EXP changed after a catch/reveal event."
    },
    {
      "type": "ui.hud_updated",
      "description": "HUD display changed after gameplay state changed."
    },
    {
      "type": "state.sampled",
      "description": "Periodic runtime state sample."
    },
    {
      "type": "validation.assertion",
      "description": "A validation assertion result."
    }
  ],
  "signalSubscriptions": [
    {
      "match": { "nodeClass": "GridSession" },
      "signal": "CellRevealed",
      "eventType": "game.reveal.result",
      "argMapping": ["position", "result", "neighborLevel"]
    },
    {
      "match": { "nodeClass": "PlayerHealthSystem" },
      "signal": "HpChanged",
      "eventType": "player.hp_changed",
      "argMapping": ["previous", "current", "reason"]
    },
    {
      "match": { "nodeClass": "PlayerProgressionSystem" },
      "signal": "ExpChanged",
      "eventType": "player.exp_changed",
      "argMapping": ["previous", "current", "source"]
    }
  ],
  "validationScenarios": [],
  "safety": {
    "defaultMode": "read-only trace inspection",
    "allowEngineActions": false
  }
}
